.product-card {
  width: 100%;
  margin-bottom: 16rpx;
  overflow: hidden;
}
.image-wrap {
  position: relative;
  width: 100%;
  padding-top: 75%;
  overflow: hidden;
  background-color: #F2F2F7;
}
.product-image {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}
.image-count {
  position: absolute;
  right: 12rpx;
  bottom: 12rpx;
  background: rgba(0,0,0,0.5);
  color: #fff;
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}
.card-info {
  padding: 16rpx;
}
.card-info .price {
  font-size: 36rpx;
  font-weight: 700;
  color: #1A1A1A;
}
.title {
  font-size: 28rpx;
  color: #1A1A1A;
  margin-top: 8rpx;
  display: block;
}
.meta {
  display: flex;
  align-items: center;
  margin-top: 8rpx;
}
.location, .time {
  font-size: 22rpx;
  color: #8E8E93;
}
.dot {
  font-size: 20rpx;
  color: #C7C7CC;
  margin: 0 8rpx;
}
