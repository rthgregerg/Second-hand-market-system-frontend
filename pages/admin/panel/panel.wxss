.admin-page { min-height: 100vh; background: #F5F5F5; }
.admin-tabs { display: flex; background: #fff; }
.atab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 30rpx; color: #8E8E93; border-bottom: 4rpx solid transparent; }
.atab.active { color: #1A1A1A; font-weight: 600; border-bottom-color: #1A1A1A; }
.stats-panel { padding: 16rpx 24rpx; display: flex; flex-wrap: wrap; gap: 16rpx; }
.stat-card { flex: 1; min-width: 40%; padding: 32rpx; text-align: center; }
.stat-key { font-size: 24rpx; color: #8E8E93; display: block; margin-bottom: 12rpx; }
.stat-val { font-size: 40rpx; font-weight: 700; display: block; }
.user-search { display: flex; gap: 16rpx; padding: 16rpx 24rpx; background: #fff; }
.user-item { display: flex; align-items: center; margin: 16rpx 24rpx; padding: 20rpx; }
.uavatar { width: 80rpx; height: 80rpx; border-radius: 50%; background: #F2F2F7; }
.uinfo { flex: 1; margin-left: 20rpx; }
.uname { font-size: 28rpx; font-weight: 500; display: block; }
.uphone { font-size: 24rpx; color: #8E8E93; margin-top: 6rpx; display: block; }
.loading-more { text-align: center; padding: 32rpx; }
.loading-text { font-size: 24rpx; color: #C7C7CC; }
