.home-page { min-height: 100vh; background-color: #F5F5F5; padding-bottom: 24rpx; }
.search-bar { position: sticky; top: 0; z-index: 100; background: #F5F5F5; padding: 16rpx 24rpx; }
.search-input { background: #FFFFFF; border-radius: 48rpx; height: 72rpx; display: flex; align-items: center; padding: 0 24rpx; }
.search-icon { font-size: 32rpx; margin-right: 12rpx; }
.search-placeholder { color: #C7C7CC; font-size: 28rpx; }
.category-scroll { white-space: nowrap; padding: 0 24rpx 16rpx; background: #F5F5F5; display: flex; }
.category-item { display: inline-flex; padding: 12rpx 32rpx; margin-right: 16rpx; background: #FFFFFF; border-radius: 48rpx; font-size: 26rpx; color: #1A1A1A; flex-shrink: 0; }
.category-item.active { background: #1A1A1A; color: #FFFFFF; }
.waterfall { display: flex; padding: 0 16rpx; gap: 16rpx; }
.waterfall-col { flex: 1; }
.loading-more { text-align: center; padding: 32rpx; }
.loading-text { font-size: 24rpx; color: #C7C7CC; }
