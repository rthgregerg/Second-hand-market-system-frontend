{
  "compilerOptions": {
    "target": "ES2017",
    "module": "CommonJS",
    "lib": ["ES2017"],
    "strict": true,
    "noImplicitAny": false,
    "moduleResolution": "node",
    "types": ["miniprogram-api-typings"],
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": [
    "typings/**/*.d.ts",
    "**/*.ts"
  ]
}
